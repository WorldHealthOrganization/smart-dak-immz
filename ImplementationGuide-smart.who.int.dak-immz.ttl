         fhir:link <http://smart.who.int/dak-immz/Requirements/IMMZFXNREQ108> ;
         fhir:reference [ fhir:v "Requirements/IMMZFXNREQ108" ]
       ] ;
       fhir:name [ fhir:v "To update client information such as including change of address (moved permanently or temporarily)" ] ;
       fhir:description [ fhir:v "As a <a href=\"ActorDefinition-Healthworker.html\">Health worker</a>, I want:\n>To update client information such as including change of address (moved permanently or temporarily)\n\nso that\n\n>To facilitate the client being contacted or being removed from a immunization session’s list" ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
