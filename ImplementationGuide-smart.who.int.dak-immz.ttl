       fhir:reference [
         fhir:link <http://smart.who.int/dak-immz/Requirements/IMMZFXNREQ019> ;
         fhir:reference [ fhir:v "Requirements/IMMZFXNREQ019" ]
       ] ;
       fhir:name [ fhir:v "To sort the list of needed vaccines by antigen" ] ;
       fhir:description [ fhir:v "As a <a href=\"ActorDefinition-Healthworker.html\">Health worker</a>, I want:\n>To sort the list of needed vaccines by antigen\n\nso that\n\n>I know how much of each vaccine is needed" ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
