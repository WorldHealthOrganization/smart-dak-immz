     fhir:resource ( [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "Requirements"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://smart.who.int/dak-immz/Requirements/IMMZFXNREQ042> ;
         fhir:reference [ fhir:v "Requirements/IMMZFXNREQ042" ]
       ] ;
       fhir:name [ fhir:v "The ability for searches to include results that look or sound similar to the search term (phonetic search)" ] ;
       fhir:description [ fhir:v "As a <a href=\"ActorDefinition-Healthworker.html\">Health worker</a>, I want:\n>The ability for searches to include results that look or sound similar to the search term (phonetic search)\n\nso that\n\n>I can find something that may be spelt incorrectly" ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "Requirements"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://smart.who.int/dak-immz/Requirements/IMMZFXNREQ056> ;
         fhir:reference [ fhir:v "Requirements/IMMZFXNREQ056" ]
       ] ;
       fhir:name [ fhir:v "The ability to associate a unique ID generated by another authority (local or global) to the record" ] ;
       fhir:description [ fhir:v "As a <a href=\"ActorDefinition-Healthworker.html\">Health worker</a>, I want:\n>The ability to associate a unique ID generated by another authority (local or global) to the record\n\nso that\n\n>The record can be more easily shared or identified with other appropriate systems" ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "Requirements"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://smart.who.int/dak-immz/Requirements/IMMZFXNREQ055> ;
         fhir:reference [ fhir:v "Requirements/IMMZFXNREQ055" ]
       ] ;
       fhir:name [ fhir:v "The ability to generate a barcode label to affix to the paper record" ] ;
       fhir:description [ fhir:v "As a <a href=\"ActorDefinition-Healthworker.html\">Health worker</a>, I want:\n>The ability to generate a barcode label to affix to the paper record\n\nso that\n\n>The record can easily be uniquely identified by scanning the ID" ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "Requirements"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://smart.who.int/dak-immz/Requirements/IMMZFXNREQ001> ;
         fhir:reference [ fhir:v "Requirements/IMMZFXNREQ001" ]
       ] ;
       fhir:name [ fhir:v "The EIR system to be able to communicate with other systems (such as a national health management information system [HMIS] and Expanded Programme on Immunization [EPI]) to obtain vaccination locations information and other necessary information" ] ;
       fhir:description [ fhir:v "As a <a href=\"ActorDefinition-ElectronicimmunizationregistryEIRstaff.html\">Electronic immunization registry (EIR) staff</a>, I want:\n>The EIR system to be able to communicate with other systems (such as a national health management information system [HMIS] and Expanded Programme on Immunization [EPI]) to obtain vaccination locations information and other necessary information\n\nso that\n\n>I will know about new vaccination locations and be informed about any updated information" ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "Requirements"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://smart.who.int/dak-immz/Requirements/IMMZFXNREQ096> ;
         fhir:reference [ fhir:v "Requirements/IMMZFXNREQ096" ]
       ] ;
       fhir:name [ fhir:v "The notification to include specific details about upcoming immunization session dates and times or outreach dates and times as appropriate" ] ;
       fhir:description [ fhir:v "As a <a href=\"ActorDefinition-Healthworker.html\">Health worker</a>, I want:\n>The notification to include specific details about upcoming immunization session dates and times or outreach dates and times as appropriate\n\nso that\n\n>The client will know specifically when and where to go to receive a vaccination" ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "Requirements"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://smart.who.int/dak-immz/Requirements/IMMZFXNREQ038> ;
         fhir:reference [ fhir:v "Requirements/IMMZFXNREQ038" ]
       ] ;
       fhir:name [ fhir:v "The search to match on partial information (such as partial birthdates)" ] ;
       fhir:description [ fhir:v "As a <a href=\"ActorDefinition-Healthworker.html\">Health worker</a>, I want:\n>The search to match on partial information (such as partial birthdates)\n\nso that\n\n>I have a better chance of finding a match" ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "Requirements"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://smart.who.int/dak-immz/Requirements/IMMZFXNREQ031> ;
         fhir:reference [ fhir:v "Requirements/IMMZFXNREQ031" ]
       ] ;
       fhir:name [ fhir:v "The system to allow barcode reading of stock taken" ] ;
       fhir:description [ fhir:v "As a <a href=\"ActorDefinition-Healthworker.html\">Health worker</a>, I want:\n>The system to allow barcode reading of stock taken\n\nso that\n\n>the system can be automatically and accurately updated" ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "Requirements"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://smart.who.int/dak-immz/Requirements/IMMZFXNREQ009> ;
         fhir:reference [ fhir:v "Requirements/IMMZFXNREQ009" ]
       ] ;
       fhir:name [ fhir:v "The system to allow conversion of a temporary vaccination location to a permanent vaccination location" ] ;
       fhir:description [ fhir:v "As a <a href=\"ActorDefinition-EIRstaff.html\">EIR staff</a>, I want:\n>The system to allow conversion of a temporary vaccination location to a permanent vaccination location\n\nso that\n\n>The data from the temporary vaccination location is not lost" ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "Requirements"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://smart.who.int/dak-immz/Requirements/IMMZFXNREQ005> ;
         fhir:reference [ fhir:v "Requirements/IMMZFXNREQ005" ]
       ] ;
       fhir:name [ fhir:v "The system to allow manual insertion of a new vaccination location not present in the NMFL in the EIR master list" ] ;
       fhir:description [ fhir:v "As a <a href=\"ActorDefinition-EIRstaff.html\">EIR staff</a>, I want:\n>The system to allow manual insertion of a new vaccination location not present in the NMFL in the EIR master list\n\nso that\n\n>I can add and use vaccination locations that are not yet in NMFL or other interconnected systems" ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "Requirements"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://smart.who.int/dak-immz/Requirements/IMMZFXNREQ030> ;
         fhir:reference [ fhir:v "Requirements/IMMZFXNREQ030" ]
       ] ;
       fhir:name [ fhir:v "The system to allow me to print the stock order(s) to be fulfilled" ] ;
       fhir:description [ fhir:v "As a <a href=\"ActorDefinition-Healthworker.html\">Health worker</a>, I want:\n>The system to allow me to print the stock order(s) to be fulfilled\n\nso that\n\n>I can use this as my pick up list, even when I am offline" ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "Requirements"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://smart.who.int/dak-immz/Requirements/IMMZFXNREQ039> ;
         fhir:reference [ fhir:v "Requirements/IMMZFXNREQ039" ]
       ] ;
       fhir:name [ fhir:v "The system to allow search parameters configuration: mandatory fields, when partial information is acceptable, etc." ] ;
       fhir:description [ fhir:v "As a <a href=\"ActorDefinition-Healthworker.html\">Health worker</a>, I want:\n>The system to allow search parameters configuration: mandatory fields, when partial information is acceptable, etc.\n\nso that\n\n>A search can be optimized without compromising confidentiality" ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "Requirements"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://smart.who.int/dak-immz/Requirements/IMMZFXNREQ083> ;
         fhir:reference [ fhir:v "Requirements/IMMZFXNREQ083" ]
       ] ;
       fhir:name [ fhir:v "The system to apply an authorised digital signature when necessary and appropriate" ] ;
       fhir:description [ fhir:v "As a <a href=\"ActorDefinition-Healthworker.html\">Health worker</a>, I want:\n>The system to apply an authorised digital signature when necessary and appropriate\n\nso that\n\n>The identity of the issuing authority can be validated" ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "Requirements"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://smart.who.int/dak-immz/Requirements/IMMZFXNREQ074> ;
         fhir:reference [ fhir:v "Requirements/IMMZFXNREQ074" ]
       ] ;
       fhir:name [ fhir:v "The system to associate the context data for each entry (e.g. the vaccination location where the dose was given, the health worker administering it)" ] ;
       fhir:description [ fhir:v "As a <a href=\"ActorDefinition-Healthworker.html\">Health worker</a>, I want:\n>The system to associate the context data for each entry (e.g. the vaccination location where the dose was given, the health worker administering it)\n\nso that\n\n>The client has a complete record and I can investigate if any issues arise" ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "Requirements"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://smart.who.int/dak-immz/Requirements/IMMZFXNREQ115> ;
         fhir:reference [ fhir:v "Requirements/IMMZFXNREQ115" ]
       ] ;
       fhir:name [ fhir:v "The system to automatically flag client records as possible duplicates by marking them as pending for review" ] ;
       fhir:description [ fhir:v "As a <a href=\"ActorDefinition-EIRstaff.html\">EIR staff</a>, I want:\n>The system to automatically flag client records as possible duplicates by marking them as pending for review\n\nso that\n\n>The health worker or EIR staff is informed and aware of pending review" ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "Requirements"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://smart.who.int/dak-immz/Requirements/IMMZFXNREQ128> ;
         fhir:reference [ fhir:v "Requirements/IMMZFXNREQ128" ]
       ] ;
       fhir:name [ fhir:v "The system to automatically flag event records as possible duplicates by marking them as pending for review" ] ;
       fhir:description [ fhir:v "As a <a href=\"ActorDefinition-EIRstaff.html\">EIR staff</a>, I want:\n>The system to automatically flag event records as possible duplicates by marking them as pending for review\n\nso that\n\n>The health worker or EIR staff is informed and aware of pending review" ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "Requirements"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://smart.who.int/dak-immz/Requirements/IMMZFXNREQ010> ;
         fhir:reference [ fhir:v "Requirements/IMMZFXNREQ010" ]
       ] ;
       fhir:name [ fhir:v "The system to automatically identify changes in vaccination locations information, retrieved from other interconnected systems, and prompt for validation" ] ;
       fhir:description [ fhir:v "As a <a href=\"ActorDefinition-EIRstaff.html\">EIR staff</a>, I want:\n>The system to automatically identify changes in vaccination locations information, retrieved from other interconnected systems, and prompt for validation\n\nso that\n\n>I will know what changes are being made and can validate them" ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "Requirements"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://smart.who.int/dak-immz/Requirements/IMMZFXNREQ137> ;
         fhir:reference [ fhir:v "Requirements/IMMZFXNREQ137" ]
       ] ;
       fhir:name [ fhir:v "The system to automatically select the most accurate/suitable vaccination event to be used as the (primary or master) record" ] ;
       fhir:description [ fhir:v "As a <a href=\"ActorDefinition-EIRstaffORhealthworker.html\">EIR staff OR health worker</a>, I want:\n>The system to automatically select the most accurate/suitable vaccination event to be used as the (primary or master) record\n\nso that\n\n>the manual review process is optimized" ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "Requirements"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://smart.who.int/dak-immz/Requirements/IMMZFXNREQ095> ;
         fhir:reference [ fhir:v "Requirements/IMMZFXNREQ095" ]
       ] ;
       fhir:name [ fhir:v "The system to automatically send reminder notification to client or designated health worker (i.e. community health worker) based on the configured reminder parameters" ] ;
       fhir:description [ fhir:v "As a <a href=\"ActorDefinition-Healthworker.html\">Health worker</a>, I want:\n>The system to automatically send reminder notification to client or designated health worker (i.e. community health worker) based on the configured reminder parameters\n\nso that\n\n>they will be alerted of an upcoming or overdue appointment" ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "Requirements"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://smart.who.int/dak-immz/Requirements/IMMZFXNREQ141> ;
