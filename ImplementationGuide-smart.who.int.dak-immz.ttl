       ] ;
       fhir:name [ fhir:v "To record in the system the results of the follow-up" ] ;
       fhir:description [ fhir:v "As a <a href=\"ActorDefinition-Communityhealthworker.html\">Community health worker</a>, I want:\n>To record in the system the results of the follow-up\n\nso that\n\n>The information is available in the system and is available for review" ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "Requirements"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://smart.who.int/dak-immz/Requirements/IMMZFXNREQ107> ;
         fhir:reference [ fhir:v "Requirements/IMMZFXNREQ107" ]
       ] ;
       fhir:name [ fhir:v "To record reason vaccine was missed" ] ;
       fhir:description [ fhir:v "As a <a href=\"ActorDefinition-Healthworker.html\">Health worker</a>, I want:\n>To record reason vaccine was missed\n\nso that\n\n>This information can be used for planning and reporting purposes" ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "Requirements"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://smart.who.int/dak-immz/Requirements/IMMZFXNREQ032> ;
         fhir:reference [ fhir:v "Requirements/IMMZFXNREQ032" ]
       ] ;
       fhir:name [ fhir:v "To record stock removed from cold storage and taken to immunization session" ] ;
       fhir:description [ fhir:v "As a <a href=\"ActorDefinition-Healthworker.html\">Health worker</a>, I want:\n>To record stock removed from cold storage and taken to immunization session\n\nso that\n\n>The count for the cold storage will be accurate, and the immunization session stock will be accounted for" ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "Requirements"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://smart.who.int/dak-immz/Requirements/IMMZFXNREQ035> ;
         fhir:reference [ fhir:v "Requirements/IMMZFXNREQ035" ]
       ] ;
       fhir:name [ fhir:v "To search for a client using at least two identifying information" ] ;
       fhir:description [ fhir:v "As a <a href=\"ActorDefinition-Healthworker.html\">Health worker</a>, I want:\n>To search for a client using at least two identifying information\n\nso that\n\n>I improve my chances of finding a match and distinguishing between similar records" ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "Requirements"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://smart.who.int/dak-immz/Requirements/IMMZFXNREQ036> ;
         fhir:reference [ fhir:v "Requirements/IMMZFXNREQ036" ]
       ] ;
       fhir:name [ fhir:v "To search for the client record given some demographic information" ] ;
       fhir:description [ fhir:v "As a <a href=\"ActorDefinition-Healthworker.html\">Health worker</a>, I want:\n>To search for the client record given some demographic information\n\nso that\n\n>I can find the client record if I do not have the unique ID" ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "Requirements"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://smart.who.int/dak-immz/Requirements/IMMZFXNREQ040> ;
         fhir:reference [ fhir:v "Requirements/IMMZFXNREQ040" ]
       ] ;
       fhir:name [ fhir:v "To search with wild cards (using a symbol to replace one or more characters)" ] ;
       fhir:description [ fhir:v "As a <a href=\"ActorDefinition-Healthworker.html\">Health worker</a>, I want:\n>To search with wild cards (using a symbol to replace one or more characters)\n\nso that\n\n>I can find something without knowing the exact spelling" ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "Requirements"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://smart.who.int/dak-immz/Requirements/IMMZFXNREQ087> ;
         fhir:reference [ fhir:v "Requirements/IMMZFXNREQ087" ]
       ] ;
       fhir:name [ fhir:v "To select one or more notification methods (e.g. automated telephone calls [i.e. robocall], text message, letter, email, community health worker notification, home visits)" ] ;
       fhir:description [ fhir:v "As a <a href=\"ActorDefinition-Healthworker.html\">Health worker</a>, I want:\n>To select one or more notification methods (e.g. automated telephone calls [i.e. robocall], text message, letter, email, community health worker notification, home visits)\n\nso that\n\n>The most appropriate notification method will be used" ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
         fhir:value [
           a fhir:string ;
           fhir:v "Requirements"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://smart.who.int/dak-immz/Requirements/IMMZFXNREQ084> ;
         fhir:reference [ fhir:v "Requirements/IMMZFXNREQ084" ]
       ] ;
       fhir:name [ fhir:v "To select reminder parameters. May include but not limited to, age range, vaccine type(s), vaccine schedules, geographic area, number of days overdue, number of reminders, etc." ] ;
       fhir:description [ fhir:v "As a <a href=\"ActorDefinition-Healthworker.html\">Health worker</a>, I want:\n>To select reminder parameters. May include but not limited to, age range, vaccine type(s), vaccine schedules, geographic area, number of days overdue, number of reminders, etc.\n\nso that\n\n>Reminders can be optimized" ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
