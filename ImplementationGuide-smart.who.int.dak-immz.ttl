       fhir:reference [
         fhir:link <http://smart.who.int/dak-immz/Requirements/IMMZFXNREQ071> ;
         fhir:reference [ fhir:v "Requirements/IMMZFXNREQ071" ]
       ] ;
       fhir:name [ fhir:v "To update stock record" ] ;
       fhir:description [ fhir:v "As a <a href=\"ActorDefinition-Healthworker.html\">Health worker</a>, I want:\n>To update stock record\n\nso that\n\n>I know which stock adjustments have not been done automatically (such as in instances if something is wasted)" ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
