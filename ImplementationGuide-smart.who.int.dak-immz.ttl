       fhir:reference [
         fhir:link <http://smart.who.int/dak-immz/Requirements/IMMZFXNREQ051> ;
         fhir:reference [ fhir:v "Requirements/IMMZFXNREQ051" ]
       ] ;
       fhir:name [ fhir:v "To select the vaccination location of the client from a list of locations" ] ;
       fhir:description [ fhir:v "As a <a href=\"ActorDefinition-Healthworker.html\">Health worker</a>, I want:\n>To select the vaccination location of the client from a list of locations\n\nso that\n\n>Entry errors are prevented" ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
