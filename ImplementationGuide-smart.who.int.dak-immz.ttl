       ] ;
       fhir:name [ fhir:v "Validate a unique identifier when system is offline" ] ;
       fhir:description [ fhir:v "As a <a href=\"ActorDefinition-Healthworker.html\">Health worker</a>, I want:\n>Validate a unique identifier when system is offline\n\nso that\n\n>Entry errors are prevented" ] ;
