         fhir:link <http://smart.who.int/dak-immz/Requirements/IMMZFXNREQ098> ;
         fhir:reference [ fhir:v "Requirements/IMMZFXNREQ098" ]
       ] ;
       fhir:name [ fhir:v "To specify thresholds for a client to qualify as requiring follow-up, based on the national immunization guidelines" ] ;
       fhir:description [ fhir:v "As a <a href=\"ActorDefinition-Healthworker.html\">Health worker</a>, I want:\n>To specify thresholds for a client to qualify as requiring follow-up, based on the national immunization guidelines\n\nso that\n\n>Follow up is only done at the appropriate time" ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
