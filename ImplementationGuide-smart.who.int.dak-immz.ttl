           a fhir:string ;
           fhir:v "Requirements"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://smart.who.int/dak-immz/Requirements/IMMZFXNREQ105> ;
         fhir:reference [ fhir:v "Requirements/IMMZFXNREQ105" ]
       ] ;
       fhir:name [ fhir:v "To send list of clients who missed immunization sessions by email or SMS to the community health worker" ] ;
       fhir:description [ fhir:v "As a <a href=\"ActorDefinition-Healthworker.html\">Health worker</a>, I want:\n>To send list of clients who missed immunization sessions by email or SMS to the community health worker\n\nso that\n\n>The community health worker will have a digital version" ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
