           a fhir:string ;
           fhir:v "Requirements"
         ]
       ] ) ;
       fhir:reference [
         fhir:link <http://smart.who.int/dak-immz/Requirements/IMMZFXNREQ073> ;
         fhir:reference [ fhir:v "Requirements/IMMZFXNREQ073" ]
       ] ;
       fhir:name [ fhir:v "To update clients’ vaccination record with all relevant information (i.e. date, dose, batch number, lot number, vaccine type, vaccine vial monitor status)" ] ;
       fhir:description [ fhir:v "As a <a href=\"ActorDefinition-Healthworker.html\">Health worker</a>, I want:\n>To update clients’ vaccination record with all relevant information (i.e. date, dose, batch number, lot number, vaccine type, vaccine vial monitor status)\n\nso that\n\n>The client has a complete record, and doses can be traced" ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
