       fhir:name [ fhir:v "To be able to manually flag duplicate records" ] ;
       fhir:description [ fhir:v "As a <a href=\"ActorDefinition-EIRstaffORhealthworker.html\">EIR staff OR health worker</a>, I want:\n>To be able to manually flag duplicate records\n\nso that\n\n>I can identify potential duplicates myself for resolution" ] ;
