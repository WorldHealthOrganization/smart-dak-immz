       ] ;
       fhir:name [ fhir:v "To be able to include vaccination locations that may not be physical permanent facilities (such as temporary or pop-up clinics)" ] ;
       fhir:description [ fhir:v "As a <a href=\"ActorDefinition-EIRstaff.html\">EIR staff</a>, I want:\n>To be able to include vaccination locations that may not be physical permanent facilities (such as temporary or pop-up clinics)\n\nso that\n\n>We will have the flexibility to accommodate temporary vaccination locations" ] ;
