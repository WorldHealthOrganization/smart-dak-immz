       fhir:reference [
         fhir:link <http://smart.who.int/dak-immz/Requirements/IMMZFXNREQ050> ;
         fhir:reference [ fhir:v "Requirements/IMMZFXNREQ050" ]
       ] ;
       fhir:name [ fhir:v "To select the place of birth from a standardized list of locations" ] ;
       fhir:description [ fhir:v "As a <a href=\"ActorDefinition-Healthworker.html\">Health worker</a>, I want:\n>To select the place of birth from a standardized list of locations\n\nso that\n\n>Entry errors are prevented" ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
