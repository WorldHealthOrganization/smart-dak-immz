       ] ;
       fhir:name [ fhir:v "To be able to merge manually duplicate records and decide what information to keep from the duplicates into a consolidated event record" ] ;
       fhir:description [ fhir:v "As a <a href=\"ActorDefinition-EIRstaffORhealthworker.html\">EIR staff OR health worker</a>, I want:\n>To be able to merge manually duplicate records and decide what information to keep from the duplicates into a consolidated event record\n\nso that\n\n>I make sure the most accurate consolidated record is kept" ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
