         fhir:reference [ fhir:v "Requirements/IMMZFXNREQ088" ]
       ] ;
       fhir:name [ fhir:v "To set client's preferred contact method" ] ;
       fhir:description [ fhir:v "As a <a href=\"ActorDefinition-Healthworker.html\">Health worker</a>, I want:\n>To set client's preferred contact method\n\nso that\n\n>Any notification will go through the client’s preferred method" ] ;
       fhir:example [
         a fhir:boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
