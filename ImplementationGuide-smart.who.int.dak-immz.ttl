         fhir:reference [ fhir:v "Requirements/IMMZFXNREQ086" ]
       ] ;
       fhir:name [ fhir:v "To validate data against the vaccine schedule (Note: Can use the vaccine schedule to best schedule reminders/recall for series vaccinations)" ] ;
       fhir:description [ fhir:v "As a <a href=\"ActorDefinition-Healthworker.html\">Health worker</a>, I want:\n>To validate data against the vaccine schedule (Note: Can use the vaccine schedule to best schedule reminders/recall for series vaccinations)\n\nso that\n\n>The generated list adheres to guidelines" ] ;
       fhir:example [
         a fhir:boolean ;
