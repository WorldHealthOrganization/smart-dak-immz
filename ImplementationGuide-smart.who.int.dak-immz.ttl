       fhir:name [ fhir:v "To be able to generate a report of clients who are inactive and disaggregate by the reason they are inactive" ] ;
       fhir:description [ fhir:v "As a <a href=\"ActorDefinition-Healthworker.html\">Health worker</a>, I want:\n>To be able to generate a report of clients who are inactive and disaggregate by the reason they are inactive\n\nso that\n\n>It can be used for reporting and planning" ] ;
