       fhir:name [ fhir:v "to be able to generate a list of clients according to defined parameters" ] ;
       fhir:description [ fhir:v "As a <a href=\"ActorDefinition-Healthworker.html\">Health worker</a>, I want:\n>to be able to generate a list of clients according to defined parameters\n\nso that\n\n>I have a list according to my needs" ] ;
